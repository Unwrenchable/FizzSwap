# Relayer configuration
RELAYER_PORT=4001
RELAYER_API_KEY=change-me-to-a-strong-secret
RELAYER_RATE_LIMIT=60

# Whether the relayer should auto-complete mapped Solana HTLCs when it observes EVM completion
RELAYER_ALLOW_AUTOCOMPLETE=false

# EVM relayer signer (use a secrets manager in production, never commit the real value)
RELAYER_PRIVATE_KEY=
FIZZDEX_ADDRESS=
EVM_RPC=

# Solana relayer keypair (JSON array of 64 bytes — use a secrets manager in production)
RELAYER_SOLANA_KEYPAIR=
SOLANA_PROGRAM_ID=
SOLANA_RPC=

# Bitcoin (optional — only required when using Bitcoin HTLC endpoints)
# BITCOIN_WIF=            WIF-encoded relayer private key (never commit the real value)
# BITCOIN_NETWORK=        "mainnet" or "testnet" (default: mainnet)
# BITCOIN_ESPLORA_URL=    Blockstream Esplora API base URL (auto-detected from BITCOIN_NETWORK if unset)
#                         mainnet: https://blockstream.info/api
#                         testnet: https://blockstream.info/testnet/api

# Optional: AES key to encrypt persisted relayer mappings (32-byte passphrase)
# RELAYER_MAPPINGS_KEY=super_secret_mapping_key
